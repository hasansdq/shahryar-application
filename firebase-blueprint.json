{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "phone": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "joinedDate": { "type": "string" },
        "learnedData": { "type": "array", "items": { "type": "string" } },
        "traits": { "type": "array", "items": { "type": "string" } },
        "customInstructions": { "type": "string" }
      },
      "required": ["id", "phone", "name"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A conversation session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "messages": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "userId", "title"]
    },
    "TaskCategory": {
      "title": "TaskCategory",
      "description": "Task Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "userId", "title"]
    },
    "Task": {
      "title": "Task",
      "description": "A planning task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "categoryId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "status", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users"
    },
    "/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "Chat Sessions"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/TaskCategory" },
      "description": "Categories"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks"
    }
  }
}
